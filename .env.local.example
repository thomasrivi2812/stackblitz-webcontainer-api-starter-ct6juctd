# Copie ce fichier en `.env.local` et renseigne l'URL de ton endpoint WordPress GraphQL.
# Tant que cette variable est vide, le site affiche des données d'exemple.
#
# Exemple avec InstaWP :
# WORDPRESS_GRAPHQL_ENDPOINT=https://ton-site.instawp.xyz/graphql

WORDPRESS_GRAPHQL_ENDPOINT=https://ndc-site-test.instawp.site/graphql
